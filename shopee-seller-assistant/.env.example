# ---------------------------------------------------------------------------
# Shopee Seller Assistant — environment for docker compose.
# Copy to .env and adjust. Start the stack with:
#   docker compose --env-file .env up --build
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=shopee
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=shopee

# --- API ---
# REQUIRED. Must be at least 16 characters. Generate a strong value, e.g.:
#   openssl rand -hex 32
AUTH_SECRET=replace-with-a-strong-32+char-random-secret
# Token lifetime in seconds (default 3600).
AUTH_TOKEN_TTL=3600

# --- Web ---
# Host port the web app is published on (container always listens on 3000).
WEB_PORT=3000
# Store identity provisioned for the single-user MVP.
STORE_NAME=Toko Saya
# One of: REGULAR | STAR | STAR_PLUS | MALL
SELLER_TIER=REGULAR
